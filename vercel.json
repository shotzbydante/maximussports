{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/social/instagram/publish.js": {
      "maxDuration": 120
    },
    "api/email/run-daily.js": {
      "maxDuration": 120
    },
    "api/email/global-send.js": {
      "maxDuration": 120
    },
    "api/user/followers.js": {
      "maxDuration": 30
    },
    "api/user/following.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "www.maximussports.ai"}],
      "destination": "https://maximussports.ai/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {"source": "/share/:id", "destination": "/api/share/render?id=:id"},
    {"source": "/march-madness-odds", "destination": "/api/seo/march-madness-odds"},
    {"source": "/upset-picks",        "destination": "/api/seo/upset-picks"},
    {"source": "/best-bracket-picks", "destination": "/api/seo/best-bracket-picks"},
    {"source": "/teams/:slug/odds",   "destination": "/api/seo/team-odds?slug=:slug"},
    {"source": "/sitemap.xml",        "destination": "/api/seo/sitemap"},

    {"source": "/",         "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/"},
    {"source": "/teams",    "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/teams"},
    {"source": "/teams/:slug", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/teams/:slug"},
    {"source": "/insights",  "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/insights"},
    {"source": "/college-basketball-picks-today", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/college-basketball-picks-today"},
    {"source": "/games",     "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/games"},
    {"source": "/games/:slug", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/games/:slug"},
    {"source": "/news",      "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/news"},
    {"source": "/march-madness-betting-intelligence", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/march-madness-betting-intelligence"},

    {"source": "/((?!api/).*)",       "destination": "/index.html"}
  ],
  "crons": [
    {"path": "/api/home/slow",                          "schedule": "*/5 * * * *"},
    {"path": "/api/ats/warm",                           "schedule": "*/7 * * * *"},
    {"path": "/api/ats/warmAll",                        "schedule": "*/10 * * * *"},
    {"path": "/api/ats/warmFull",                       "schedule": "*/30 * * * *"},
    {"path": "/api/email/run-daily?type=daily",         "schedule": "0 13 * * *"},
    {"path": "/api/email/run-daily?type=news",          "schedule": "30 16 * * *"},
    {"path": "/api/email/run-daily?type=odds",          "schedule": "15 19 * * *"},
    {"path": "/api/email/run-daily?type=pinned",        "schedule": "45 22 * * *"},
    {"path": "/api/email/run-daily?type=teamDigest",   "schedule": "30 2 * * *"}
  ]
}
