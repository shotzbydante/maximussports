{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/social/instagram/publish.js": {
      "maxDuration": 120
    },
    "api/social/instagram/publish-carousel.js": {
      "maxDuration": 120
    },
    "api/social/instagram/autopost-mlb-daily.js": {
      "maxDuration": 180,
      "memory": 1024
    },
    "api/email/run-daily.js": {
      "maxDuration": 120
    },
    "api/email/global-send.js": {
      "maxDuration": 120
    },
    "api/user/followers.js": {
      "maxDuration": 30
    },
    "api/user/following.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "www.maximussports.ai"}],
      "destination": "https://maximussports.ai/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {"source": "/share/:id", "destination": "/api/share/render?id=:id"},
    {"source": "/ncaam/march-madness-odds", "destination": "/api/seo/march-madness-odds"},
    {"source": "/ncaam/upset-picks",        "destination": "/api/seo/upset-picks"},
    {"source": "/ncaam/best-bracket-picks", "destination": "/api/seo/best-bracket-picks"},
    {"source": "/ncaam/teams/:slug/odds",   "destination": "/api/seo/team-odds?slug=:slug"},
    {"source": "/march-madness-odds", "destination": "/api/seo/march-madness-odds"},
    {"source": "/upset-picks",        "destination": "/api/seo/upset-picks"},
    {"source": "/best-bracket-picks", "destination": "/api/seo/best-bracket-picks"},
    {"source": "/teams/:slug/odds",   "destination": "/api/seo/team-odds?slug=:slug"},
    {"source": "/sitemap.xml",        "destination": "/api/seo/sitemap"},

    {"source": "/ncaam",         "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam"},
    {"source": "/ncaam/teams",    "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/teams"},
    {"source": "/ncaam/teams/:slug", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/teams/:slug"},
    {"source": "/ncaam/insights",  "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/insights"},
    {"source": "/ncaam/college-basketball-picks-today", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/college-basketball-picks-today"},
    {"source": "/ncaam/games",     "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/games"},
    {"source": "/ncaam/games/:slug", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/games/:slug"},
    {"source": "/ncaam/news",      "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/news"},
    {"source": "/ncaam/march-madness-betting-intelligence", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/march-madness-betting-intelligence"},

    {"source": "/",         "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam"},
    {"source": "/teams",    "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/teams"},
    {"source": "/teams/:slug", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/teams/:slug"},
    {"source": "/insights",  "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/insights"},
    {"source": "/college-basketball-picks-today", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/college-basketball-picks-today"},
    {"source": "/games",     "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/games"},
    {"source": "/games/:slug", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/games/:slug"},
    {"source": "/news",      "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/news"},
    {"source": "/march-madness-betting-intelligence", "has": [{"type": "header", "key": "user-agent", "value": "(?i).*(Twitterbot|facebookexternalhit|Facebot|Slackbot|Slack-ImgProxy|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot|PinterestBot|Embedly|Quora Link Preview|vkShare).*"}], "destination": "/api/meta?path=/ncaam/march-madness-betting-intelligence"},

    {"source": "/((?!api/).*)",       "destination": "/index.html"}
  ],
  "crons": [
    {"path": "/api/home/slow",                          "schedule": "*/5 * * * *"},
    {"path": "/api/ats/warm",                           "schedule": "*/7 * * * *"},
    {"path": "/api/ats/warmAll",                        "schedule": "*/10 * * * *"},
    {"path": "/api/ats/warmFull",                       "schedule": "*/30 * * * *"},
    {"path": "/api/email/run-daily?type=global_briefing",   "schedule": "0 13 * * *"},
    {"path": "/api/email/run-daily?type=mlb_briefing",      "schedule": "30 16 * * *"},
    {"path": "/api/email/run-daily?type=mlb_team_digest",   "schedule": "30 2 * * *"},
    {"path": "/api/email/run-daily?type=mlb_picks",         "schedule": "15 19 * * *"},
    {"path": "/api/email/run-daily?type=ncaam_briefing",    "schedule": "0 14 * * *"},
    {"path": "/api/email/run-daily?type=ncaam_team_digest", "schedule": "45 22 * * *"},
    {"path": "/api/email/run-daily?type=ncaam_picks",       "schedule": "0 20 * * *"},
    {"path": "/api/social/instagram/autopost-mlb-daily?mode=live", "schedule": "0 13 * * *"}
  ]
}
