# Google News — team headlines use free RSS feeds (no key needed).

# Optional: The Odds API (https://the-odds-api.com/) for live spreads, totals, moneyline
ODDS_API_KEY=

# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=
# Optional: override the "from" address (default: winning@maximussports.ai)
# RESEND_FROM=winning@maximussports.ai

# Optional: app URL for magic-link redirects (default: https://maximussports.ai)
# APP_URL=https://maximussports.ai

# ── Stripe (subscription billing) ───────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# The Price ID for the Pro monthly plan (create in Stripe Dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_...

# Webhook signing secret (Stripe Dashboard → Webhooks → your endpoint → signing secret)
# For local dev use: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Vercel / Cron ────────────────────────────────────────────────────────────
CRON_SECRET=

# ── Analytics ────────────────────────────────────────────────────────────────
VITE_POSTHOG_KEY=
# Server-side PostHog (optional aliases — falls back to VITE_POSTHOG_KEY / VITE_POSTHOG_HOST)
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://app.posthog.com
